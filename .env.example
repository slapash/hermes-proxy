# hermes-proxy configuration
# Copy this file to .env and fill in your values.

# Required: password for the web UI login screen
HERMES_PROXY_PASSWORD=changeme

# Required: bearer token for the Hermes api_server platform
# Find this in ~/.hermes/config.yaml under api_server.api_key
API_SERVER_KEY=your-api-server-key-here

# Optional: URL of the Hermes api_server (default: http://127.0.0.1:8642)
API_SERVER_URL=http://127.0.0.1:8642

# Optional: path to Hermes state.db (default: ~/.hermes/state.db)
# STATE_DB_PATH=/custom/path/to/state.db
